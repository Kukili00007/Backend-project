APP_ENV=development
SECRET_KEY=change-me-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=postgresql+asyncpg://leanstock:leanstock@postgres:5432/leanstock_db
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
RESERVATION_TTL_SECONDS=900
AUTH_RATE_LIMIT_PER_MINUTE=5
DECAY_START_DAYS=30
DECAY_INTERVAL_HOURS=72
DECAY_DISCOUNT_PCT=10
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
FROM_EMAIL=noreply@leanstock.kz
SENDGRID_API_KEY=
EMAIL_PROVIDER=gmail_oauth2
EMAIL_ENABLED=true
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=replace-with-google-oauth-refresh-token
GOOGLE_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token
GMAIL_SENDER_EMAIL=your-gmail-address@gmail.com
FRONTEND_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
